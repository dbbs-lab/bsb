{
  "name": "bsb-native",
  "$schema": "../../.nx/installation/node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/bsb-native/bsb_native",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "maturin build --release --out dist",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "cargo test",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "nx-release-publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'bsb-native wheels are built and published by the maturin-action matrix in .github/workflows/wheels.yml, not by nx release.'"
      },
      "outputs": []
    }
  },
  "tags": [],
  "release": {
    "version": {
      "generator": "@nxlv/python:release-version"
    }
  }
}
